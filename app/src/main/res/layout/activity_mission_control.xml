<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tv_mission_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mission Control"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Crew A"
            android:textColor="@color/text_primary"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/rg_crew_a"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/surface"
            android:orientation="vertical"
            android:padding="12dp" />

        <TextView
            android:id="@+id/tv_crew_a_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@color/surface"
            android:minHeight="56dp"
            android:padding="12dp"
            android:textColor="@color/text_primary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Crew B"
            android:textColor="@color/text_primary"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/rg_crew_b"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/surface"
            android:orientation="vertical"
            android:padding="12dp" />

        <TextView
            android:id="@+id/tv_crew_b_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@color/surface"
            android:minHeight="56dp"
            android:padding="12dp"
            android:textColor="@color/text_primary" />

        <Button
            android:id="@+id/btn_start_mission"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Start Mission" />

        <Button
            android:id="@+id/btn_back"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Back" />
    </LinearLayout>
</ScrollView>
